#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/glq-setup.log) 2>&1

# Deep Learning AMI: NVIDIA drivers + CUDA pre-installed.
# g5 instances have NVMe SSD at /opt/dlami/nvme (419 GB).
# Root EBS is only 100 GB — use NVMe for everything large.

NVME=/opt/dlami/nvme
VENV=/home/ubuntu/venv
HF_CACHE=$NVME/hf_cache

echo "=== GLQ setup starting ==="

apt-get update -qq && apt-get install -y -qq python3-venv libpcre3-dev > /dev/null 2>&1
# libpcre3-dev is a build-time dep of pypcre, which gptqmodel's setup.py
# imports at metadata-generation time (see user-block install below).

# Fix CUDA: DLAMI hardcodes older cuda paths in /etc/environment and /etc/profile.d/dlami.sh.
# Replace them with /usr/local/cuda/bin so the symlink controls which version is used.
ln -sfn /usr/local/cuda-12.9 /usr/local/cuda
sed -i 's|/usr/local/cuda-[0-9.]*/bin:/usr/local/cuda-[0-9.]*/include:||g' /etc/environment
sed -i 's|PATH="|PATH="/usr/local/cuda/bin:|' /etc/environment
# Fix /etc/profile.d/dlami.sh which overrides PATH for login shells
sed -i 's|/usr/local/cuda-[0-9.]*/bin:/usr/local/cuda-[0-9.]*/include||g' /etc/profile.d/dlami.sh 2>/dev/null || true
sed -i 's|/usr/local/cuda-[0-9.]*/lib[^:]*:||g' /etc/profile.d/dlami.sh 2>/dev/null || true

sudo -u ubuntu bash <<USERSCRIPT
set -euo pipefail

export PATH=/usr/local/cuda/bin:$PATH

# Venv on NVMe
python3 -m venv $VENV
source $VENV/bin/activate

# Core deps. vLLM 0.19.0 pins torch==2.10.0 but NemotronH's custom cpp
# extensions want torch >= 2.11, so we pin 2.11 and accept vllm-version drift.
# Must match the host CUDA — the DLAMI ships cuda-12.9, so we use the cu128
# wheel index (forward-compat within 12.x). Without +cu128 / --index-url pip
# pulls the default cu130 wheel, which then fails with a cuda-version mismatch
# when fast_hadamard_transform / mamba-ssm / causal-conv1d try to build
# against it with CUDA_HOME=/usr/local/cuda-12.9.
pip install -q pip --upgrade
pip install -q vllm==0.20.0
pip install -q 'glq[quantize]==${glq_version}' ninja wheel
# mamba-ssm and causal-conv1d need CUDA_HOME for building
export CUDA_HOME=/usr/local/cuda-12.9
unset CUDA_HOME
# Pin torch LAST — mamba-ssm may pull a newer version as a dependency
pip install -q torch==2.11.0+cu128 torchvision==0.26.0+cu128 torchaudio==2.11.0+cu128 --index-url https://download.pytorch.org/whl/cu128
pip install 'fast_hadamard_transform @ git+https://github.com/Dao-AILab/fast-hadamard-transform.git' --no-build-isolation
pip install "mistral-common[hf-hub]"
pip install 'transformers>=5.0' 'huggingface_hub>=0.30'
pip install -q causal-conv1d --no-build-isolation || echo "WARNING: causal-conv1d failed"
pip install -q mamba-ssm --no-build-isolation || echo "WARNING: mamba-ssm failed — Nemotron models unavailable"
pip install -q lm-eval langdetect immutabledict
pip install -q pypcre
pip install -q gptqmodel --no-build-isolation
pip install -q optimum  # required by HF transformers to *load* GPTQ models
# HF cache on NVMe. Symlink ~/.cache/huggingface to the NVMe location so
# tooling that ignores HF_HOME (non-interactive ssh, services, any subprocess
# that doesn't inherit an interactive shell env) still lands on the fast disk.
# The root EBS is only 100 GB — a single large model download will fill it.
mkdir -p $HF_CACHE
mkdir -p ~/.cache
rm -rf ~/.cache/huggingface
ln -s $HF_CACHE ~/.cache/huggingface
echo "export HF_HOME=$HF_CACHE" >> ~/.bashrc
echo "source $VENV/bin/activate" >> ~/.bashrc

echo "Setup complete" > /tmp/setup-done
USERSCRIPT

# Symlink ninja to system PATH (needs root, after venv created above)
ln -sf $VENV/bin/ninja /usr/local/bin/ninja

sudo echo "export PATH=\"/opt/dlami/nvme/venv/bin:$PATH\"" > /etc/profile.d/ninja.sh
sudo chmod 755 /etc/profile.d/ninja.sh
sudo apt-get install -y -qq nsight-systems-2025.3
sudo apt-get install -y -qq mosh

echo "=== GLQ setup done ==="
