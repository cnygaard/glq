#!/bin/bash
set -euo pipefail

# Deep Learning AMI already has NVIDIA drivers + CUDA.
# Install Python deps into a venv.

apt-get update -qq && apt-get install -y -qq python3-venv > /dev/null 2>&1

sudo -u ubuntu bash <<'USERSCRIPT'
cd ~
python3 -m venv .venv
source .venv/bin/activate
pip install -q torch torchvision --index-url https://download.pytorch.org/whl/cu124
pip install -q transformers datasets accelerate safetensors sentencepiece
echo "Setup complete" > /tmp/setup-done
USERSCRIPT
